# Server
PORT=8000
HOST=0.0.0.0
DEBUG=false

# CORS — comma-separated, no spaces
# Dev: CORS_ORIGINS=*
# Prod: CORS_ORIGINS=https://tokitube.vercel.app,https://yourdomain.com
CORS_ORIGINS=https://tokitube.vercel.app

# Rate Limiting
RATE_LIMIT=30 per minute

# Storage Limits
MAX_FILE_SIZE_MB=500
MIN_FREE_SPACE_MB=1000
FILE_TTL_MINUTES=30

# Download
YDL_TIMEOUT=300
